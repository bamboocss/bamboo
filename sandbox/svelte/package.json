{
  "name": "sandbox-svelte",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "bamboo",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "oxfmt --check . && eslint .",
    "format": "oxfmt .",
    "css": "BAMBOO_DEBUG=ast:* bamboo",
    "css:gen": "BAMBOO_DEBUG=* bamboo codegen",
    "css:dev": "BAMBOO_DEBUG=file:* bamboo --watch"
  },
  "devDependencies": {
    "@bamboocss/dev": "workspace:*",
    "@sveltejs/adapter-auto": "7.0.0",
    "@sveltejs/kit": "2.49.1",
    "@sveltejs/vite-plugin-svelte": "6.2.1",
    "autoprefixer": "10.4.22",
    "eslint-plugin-svelte3": "4.0.0",
    "oxfmt": "0.51.0",
    "postcss": "8.5.14",
    "postcss-load-config": "6.0.1",
    "svelte": "5.45.4",
    "svelte-check": "4.3.4",
    "svelte-preprocess": "6.0.3",
    "tslib": "2.8.1",
    "typescript": "6.0.2",
    "vite": "7.2.6"
  }
}
