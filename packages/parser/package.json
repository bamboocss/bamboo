{
  "name": "@bamboocss/parser",
  "version": "1.11.2",
  "description": "The static parser for bamboo css",
  "homepage": "https://bamboo-css.com",
  "license": "MIT",
  "author": "Segun Adebayo <joseshegs@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bamboocss/bamboo.git",
    "directory": "packages/parser"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.cts",
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format=esm,cjs --dts",
    "build-fast": "tsdown --dts=false src/index.ts --format=esm,cjs",
    "dev": "pnpm build-fast --watch"
  },
  "dependencies": {
    "@bamboocss/config": "workspace:^",
    "@bamboocss/core": "workspace:^",
    "@bamboocss/extractor": "workspace:*",
    "@bamboocss/logger": "workspace:*",
    "@bamboocss/shared": "workspace:*",
    "@bamboocss/types": "workspace:*",
    "ts-morph": "28.0.0",
    "ts-pattern": "5.9.0"
  },
  "devDependencies": {
    "@bamboocss/generator": "workspace:*",
    "@bamboocss/plugin-svelte": "workspace:*",
    "@bamboocss/plugin-vue": "workspace:*"
  }
}
