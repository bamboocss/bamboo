{
  "name": "@bamboocss/types",
  "version": "1.11.4",
  "description": "The types for css bamboo",
  "homepage": "https://bamboo-css.com",
  "license": "MIT",
  "author": "Segun Adebayo <joseshegs@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bamboocss/bamboo.git",
    "directory": "packages/types"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "dist/index.d.cts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.cts",
      "default": "./dist/index.d.cts"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "ncp node_modules/csstype/index.d.ts src/csstype.d.ts",
    "dev": "tsx scripts/watch.ts",
    "build": "cross-env BAMBOO_BUILD=1 tsx scripts/postbuild.ts && tsx scripts/build.ts"
  },
  "devDependencies": {
    "@bamboocss/extractor": "workspace:*",
    "csstype": "3.2.3",
    "microdiff": "1.5.0",
    "ncp": "2.0.0",
    "pkg-types": "2.3.0",
    "ts-morph": "28.0.0"
  }
}
