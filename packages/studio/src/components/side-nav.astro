---
import { bamboo, Stack } from '../../styled-system/jsx'
import { navItems } from '../lib/constants'
import { getUrl } from "../lib/url"
import SideNavItem from './side-nav-item.astro'
---

<bamboo.nav marginTop="8">
  <Stack gap="10">
    <div>
      <bamboo.span fontWeight="bold" fontSize="small" opacity="0.7">TOKENS</bamboo.span>
      <bamboo.ul mb="8" listStyleType="none" p="0" my="2" mx="0">
        {
          navItems
            .filter((item) => item.type === 'token')
            .map((item) => <SideNavItem href={getUrl(item.id)}>{item.label}</SideNavItem>)
        }
      </bamboo.ul>
    </div>
    <div>
      <bamboo.span fontWeight="bold" fontSize="small" opacity="0.7">PLAYGROUND</bamboo.span>
      <bamboo.ul listStyleType="none" p="0" my="2" mx="0">
        {
          navItems
            .filter((item) => item.type === 'playground')
            .map((item) => <SideNavItem href={getUrl(item.id)}>{item.label}</SideNavItem>)
        }
      </bamboo.ul>
    </div>
  </Stack>
</bamboo.nav>
