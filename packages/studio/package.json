{
  "name": "@bamboocss/studio",
  "version": "1.11.1",
  "description": "The automated token documentation for Bamboo CSS",
  "keywords": [
    "bamboo",
    "design tokens",
    "documentation",
    "studio"
  ],
  "homepage": "https://bamboo-css.com",
  "license": "MIT",
  "author": "Segun Adebayo <joseshegs@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chakra-ui/bamboo.git",
    "directory": "packages/studio"
  },
  "files": [
    "dist",
    "src",
    "public",
    "styled-system",
    "tsconfig.json",
    "*.ts",
    "*.mjs"
  ],
  "sideEffects": false,
  "main": "dist/studio.js",
  "module": "dist/studio.mjs",
  "types": "dist/studio.d.ts",
  "exports": {
    ".": {
      "types": "./dist/studio.d.ts",
      "require": "./dist/studio.js",
      "import": {
        "types": "./dist/studio.d.mts",
        "default": "./dist/studio.mjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "bamboo": "node ../cli/bin.js",
    "codegen": "node ../cli/bin.js codegen",
    "build": "tsup",
    "postbuild": "pnpm bamboo",
    "build-fast": "tsup --no-dts",
    "dev": "pnpm build-fast --watch",
    "dev:bamboo": "node ../cli/bin.js --clean --watch",
    "dev:astro": "astro dev",
    "start": "concurrently \"pnpm dev:bamboo\" \"pnpm dev:astro\""
  },
  "dependencies": {
    "@astrojs/react": "5.0.4",
    "@bamboocss/astro-plugin-studio": "workspace:*",
    "@bamboocss/config": "workspace:*",
    "@bamboocss/logger": "workspace:*",
    "@bamboocss/shared": "workspace:*",
    "@bamboocss/token-dictionary": "workspace:*",
    "@bamboocss/types": "workspace:*",
    "@nanostores/react": "^1.0.0",
    "astro": "6.2.2",
    "nanostores": "^1.1.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "vite": "7.3.2"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3"
  }
}
