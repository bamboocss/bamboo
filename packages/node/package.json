{
  "name": "@bamboocss/node",
  "version": "1.11.1",
  "description": "The core css bamboo library",
  "homepage": "https://bamboo-css.com",
  "license": "MIT",
  "author": "Segun Adebayo <joseshegs@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bamboocss/bamboo.git",
    "directory": "packages/node"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.cts",
      "require": "./dist/index.cjs",
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --tsconfig tsconfig.build.json src/index.ts --format=cjs,esm --shims --dts",
    "build-fast": "tsdown --dts=false --tsconfig tsconfig.build.json src/index.ts --format=cjs,esm --shims",
    "dev": "pnpm build-fast --watch"
  },
  "dependencies": {
    "@bamboocss/config": "workspace:*",
    "@bamboocss/core": "workspace:*",
    "@bamboocss/generator": "workspace:*",
    "@bamboocss/logger": "workspace:*",
    "@bamboocss/parser": "workspace:*",
    "@bamboocss/plugin-lightningcss": "workspace:*",
    "@bamboocss/plugin-svelte": "workspace:*",
    "@bamboocss/plugin-vue": "workspace:*",
    "@bamboocss/reporter": "workspace:*",
    "@bamboocss/shared": "workspace:*",
    "@bamboocss/token-dictionary": "workspace:*",
    "@bamboocss/types": "workspace:*",
    "browserslist": "4.28.1",
    "chokidar": "4.0.3",
    "fast-glob": "3.3.3",
    "fs-extra": "11.3.2",
    "get-tsconfig": "^4.13.0",
    "glob-parent": "6.0.2",
    "is-glob": "4.0.3",
    "lodash.merge": "4.6.2",
    "look-it-up": "2.1.0",
    "outdent": " ^0.8.0",
    "p-limit": "5.0.0",
    "package-manager-detector": "1.6.0",
    "perfect-debounce": "1.0.0",
    "picomatch": "4.0.4",
    "pkg-types": "2.3.0",
    "pluralize": "8.0.0",
    "postcss": "8.5.14",
    "ts-morph": "28.0.0",
    "ts-pattern": "5.9.0"
  },
  "devDependencies": {
    "@types/fs-extra": "11.0.4",
    "@types/glob-parent": "5.1.3",
    "@types/is-glob": "4.0.4",
    "@types/picomatch": "4.0.2",
    "boxen": "8.0.1"
  }
}
